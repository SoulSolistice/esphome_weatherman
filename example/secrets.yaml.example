## Copy this file to secrets.yaml (which is gitignored) and fill in.
## Generate the api/ota keys with: openssl rand -base64 32

wifi-ssid: "YourWiFi"
wifi-password: "YourWiFiPassword"
wifi-ap-password: "RecoveryAPPassword"

# Base64-encoded 32-byte key for native API encryption.
# `esphome run` will offer to generate one if missing; copy the value here.
esphome-api: "+QHGYK4i7..."

# OTA password protects firmware updates.
esphome-ota: "your-strong-ota-password"
